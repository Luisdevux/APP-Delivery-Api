# MongoDB Local (Docker)
DB_URL="mongodb://localhost:27017/appDelivery"

# MongoDB Local para Testes (Docker)
DB_URL_TEST="mongodb://localhost:27017/appDelivery_teste"

# Porta da aplicação
API_PORT=3000

# Variável de desenvolvimento
NODE_ENV=development

# Ativar logs de depuração (true ou false)
DEBUGLOG=true

# URL de desenvolvimento do Swagger
SWAGGER_DEV_URL="http://localhost:3000/"

# URL de produção do Swagger
SWAGGER_PROD_URL="http://localhost:3000/prod"

# JWT (JSON Web Token) Configurações
JWT_SECRET_ACCESS_TOKEN=
JWT_SECRET_REFRESH_TOKEN=
JWT_SECRET_PASSWORD_RECOVERY=senha_recuperacao_secret_key_32chars_min
JWT_ACCESS_TOKEN_EXPIRATION="2m"
JWT_REFRESH_TOKEN_EXPIRATION="3d"
JWT_PASSWORD_RECOVERY_EXPIRATION="1h"
# O JWT Refresh Token só é concedido, se não estiver vencido, no /login. Em /refresh, apenas se esse valor for true.
SINGLE_SESSION_REFRESH_TOKEN=false

# Configurações do Garage (S3-compatible storage)
# Endpoint do servidor Garage (sem http/https)
GARAGE_ENDPOINT=localhost
# Porta do Garage
GARAGE_PORT=9000
# Usar SSL (true/false)
GARAGE_USE_SSL=false
# URL pública para acessar as imagens armazenadas no Garage
GARAGE_PUBLIC_URL=http://localhost:9000
# Chave de acesso do Garage
GARAGE_ACCESS_KEY=sua-chave-de-acesso
# Chave secreta do Garage
GARAGE_SECRET_KEY=sua-chave-secreta
# Nome do bucket para armazenar fotos
GARAGE_BUCKET_FOTOS=seu-bucket-de-fotos

# Configurações de Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_FROM="App Delivery <noreply@seuapp.com>"
